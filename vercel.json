{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "build-ctx/html",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/:path*.(lh|ls|atlas)",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/:path*.(sk|shader)",
      "headers": [
        { "key": "Content-Type", "value": "application/octet-stream" },
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/:path*.(js|json|png|jpg|jpeg|webp|mp3|wav|ico|css|svg|wasm|ttf|woff|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path*.shader",
      "destination": "/:path.shader.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
